# Application
APP_ENV=production
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_NAME=veranda_my
DB_USER=veranda_my
DB_PASS=
DB_TABLE_SUFFIX=

# Poster POS
POSTER_API_TOKEN=
POSTER_SPOT_TIMEZONE=Europe/Moscow

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
TELEGRAM_WEBHOOK_SECRET=

# Auth
SESSION_SECRET=
AUTH_ALLOWED_EMAILS=

# WhatsApp bridge
WA_BRIDGE_URL=
WA_BRIDGE_SECRET=

# ─── /onlineorder — public delivery checkout ──────────────────────
# Location & rules
ONLINEORDER_RESTAURANT_LAT=12.238791
ONLINEORDER_RESTAURANT_LNG=109.196749
ONLINEORDER_RESTAURANT_ADDRESS=Veranda, Nha Trang
ONLINEORDER_PHONE=
ONLINEORDER_MIN_ORDER_VND=0
ONLINEORDER_MAX_RADIUS_KM=15
# Address autocomplete + server geocoding: google | nominatim
ONLINEORDER_GEOCODER=google
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_KEY=
# Delivery quote provider: grab | maxim | distance | none
ONLINEORDER_DELIVERY_PROVIDER=grab
# When grab/maxim creds are missing: distance | none
ONLINEORDER_DELIVERY_FALLBACK=distance
# Keyless distance tariff (used in fallback/testing mode)
ONLINEORDER_DELIVERY_BASE_VND=15000
ONLINEORDER_DELIVERY_PER_KM_VND=5000
ONLINEORDER_DELIVERY_MIN_VND=15000
ONLINEORDER_DELIVERY_ROAD_FACTOR=1.3
# Auto-book courier right after order creation (keep false until
# payment auto-confirmation exists)
ONLINEORDER_AUTO_DISPATCH=false
# Grab Express partner credentials
GRAB_API_BASE=https://partner-api.grab.com
GRAB_CLIENT_ID=
GRAB_CLIENT_SECRET=
GRAB_MERCHANT_ID=
GRAB_SANDBOX=true
# Maxim partner API (issued under partner contract)
MAXIM_API_BASE=
MAXIM_API_KEY=
MAXIM_CITY_ID=
# Food prepayment QR: vietqr | sepay | none
ONLINEORDER_PAY_QR_PROVIDER=vietqr
VIETQR_BANK_BIN=
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=
VIETQR_TEMPLATE=compact2
# Telegram alert about new orders (falls back to TELEGRAM_CHAT_ID)
ONLINEORDER_TG_CHAT_ID=
ONLINEORDER_TG_THREAD_ID=
