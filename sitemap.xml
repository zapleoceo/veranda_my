<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap для публичных страниц veranda.my.

  Правила, по которым он собран:
    1. Каждая страница присутствует ровно одним <url> блоком —
       языковые варианты идут внутри как <xhtml:link rel="alternate">.
       Дублировать <url> с ?lang=ru было ошибкой: Google и так понимает
       альтернативы через hreflang, а дубль <loc> размывает каноникал.
    2. В <loc> попадает ТОЛЬКО та URL, что отдаёт 200 без редиректа.
       nginx добавляет trailing slash к директориям через
       301 → http:// (даунгрейд протокола, баг mod_dir), поэтому:
         - /links/  (со слэшем) — финальный URL, не /links
         - /tr3/    (со слэшем) — финальный URL, не /tr3
    3. <loc> совпадает с тем, что страница объявляет в
       <link rel="canonical"> — иначе Google видит конфликт.
       /links/, /links/menu и /tr3/ всё это согласовано.

  Не публичные (и не в sitemap, и Disallow в robots.txt):
    /admin/*, /payday3/*, /sepay/*, /schedule/*,
    /banya, /roma, /employees, /reservations, /zapara, /rawdata,
    /kitchen_online, /neworder/*, /api/*, /cron/*, /scripts/*,
    /login, /logout, /auth_*, /telegram_*, /analytics.php,
    /daily_summary.php, /dashboard*, /set_tg_webhook.php.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

    <!-- ─── Главная (3 языка в корне домена — каждый язык свой <url>) ── -->
    <url>
        <loc>https://veranda.my/en/</loc>
        <lastmod>2026-06-08</lastmod>
        <changefreq>weekly</changefreq>
        <priority>1.0</priority>
        <xhtml:link rel="alternate" hreflang="x-default" href="https://veranda.my/en/"/>
        <xhtml:link rel="alternate" hreflang="en"        href="https://veranda.my/en/"/>
        <xhtml:link rel="alternate" hreflang="ru"        href="https://veranda.my/ru/"/>
        <xhtml:link rel="alternate" hreflang="vi"        href="https://veranda.my/vi/"/>
    </url>
    <url>
        <loc>https://veranda.my/ru/</loc>
        <lastmod>2026-06-08</lastmod>
        <changefreq>weekly</changefreq>
        <priority>1.0</priority>
        <xhtml:link rel="alternate" hreflang="x-default" href="https://veranda.my/en/"/>
        <xhtml:link rel="alternate" hreflang="en"        href="https://veranda.my/en/"/>
        <xhtml:link rel="alternate" hreflang="ru"        href="https://veranda.my/ru/"/>
        <xhtml:link rel="alternate" hreflang="vi"        href="https://veranda.my/vi/"/>
    </url>
    <url>
        <loc>https://veranda.my/vi/</loc>
        <lastmod>2026-06-08</lastmod>
        <changefreq>weekly</changefreq>
        <priority>1.0</priority>
        <xhtml:link rel="alternate" hreflang="x-default" href="https://veranda.my/en/"/>
        <xhtml:link rel="alternate" hreflang="en"        href="https://veranda.my/en/"/>
        <xhtml:link rel="alternate" hreflang="ru"        href="https://veranda.my/ru/"/>
        <xhtml:link rel="alternate" hreflang="vi"        href="https://veranda.my/vi/"/>
    </url>

    <!-- ─── IG bio landing (4 языка) ─────────────────────────── -->
    <url>
        <loc>https://veranda.my/links/</loc>
        <lastmod>2026-06-01</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
        <xhtml:link rel="alternate" hreflang="x-default" href="https://veranda.my/links/"/>
