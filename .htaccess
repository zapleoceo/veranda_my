DirectorySlash Off

RewriteEngine On

RewriteRule ^home/?$ home/index.php [L,QSA]
RewriteRule ^links/?$ links/index.php [L,QSA]
RewriteRule ^sepay/?$ sepay/index.php [L,QSA]
RewriteRule ^tr3/?$ tr3/index.php [L,QSA]
RewriteRule ^tr3/api/?$ tr3/api.php [L,QSA]
RewriteRule ^tr4/?$ tr4/index.php [L,QSA]
RewriteRule ^tr4/api/?$ tr4/api.php [L,QSA]
RewriteRule ^neworder/?$ neworder/index.php [L,QSA]
RewriteRule ^onlineorder/?$ onlineorder/index.php [L,QSA]
RewriteRule ^poster-app/?$ poster-app/index.php [L,QSA]
# TableReservation.php был удалён — rewrite больше не нужен.

# Redirects from old .php paths to new folders
RewriteRule ^banya\.php$ /banya [R=301,L]
RewriteRule ^roma\.php$ /roma [R=301,L]
RewriteRule ^employees\.php$ /employees [R=301,L]
RewriteRule ^reservations\.php$ /reservations [R=301,L]
RewriteRule ^logs\.php$ /admin/logs [R=301,L,QSA]

# Routes for new folders. Each <module>/index.php has a SLIM_RUNNING guard
# that delegates to public/index.php — Slim then renders via layout.php.
# admin/ was deleted entirely; nginx try_files falls /admin through to Slim.
RewriteRule ^banya/?$ banya/index.php [L,QSA]
RewriteRule ^roma/?$ roma/index.php [L,QSA]
RewriteRule ^employees/?$ employees/index.php [L,QSA]
RewriteRule ^reservations/?$ reservations/index.php [L,QSA]


# Catch-all: /foo → /foo.php (если /foo.php существует и /foo это не директория).
# Благодаря этому правилу /links/menu, /login, /logout и т.п. отвечают тем
# же контентом что и .php-аналог — пара URL'ов работает одинаково.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]
